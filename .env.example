# ═══════════════════════════════════════════════════════════════
# HealthBook — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ── SERVER ──────────────────────────────────────────────────────
# Change this to a long random string in production:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-in-production
FLASK_DEBUG=false

# ── GOOGLE OAUTH ─────────────────────────────────────────────────
# Required for "Continue with Google" login.
# Setup steps:
#   1. Go to https://console.cloud.google.com/
#   2. Create a project → APIs & Services → Credentials
#   3. Create OAuth 2.0 Client ID (Web application)
#   4. Add Authorised redirect URIs:
#        http://localhost:5000/auth/google/callback        (dev)
#        https://yourdomain.com/auth/google/callback       (prod)
#   5. Copy Client ID and Secret below.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── FIREBASE PHONE OTP ────────────────────────────────────────────
# Required for "Sign in with Phone" OTP.
# Setup steps:
#   1. Go to https://console.firebase.google.com/
#   2. Create a project (or use existing Google project)
#   3. Authentication → Sign-in method → Enable Phone
#   4. Project Settings → General → Your apps → Add Web App
#   5. Copy apiKey and projectId below.
#   6. In Firebase console → Authentication → Settings → Authorized domains
#      add your domain (localhost is included by default).
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_PROJECT_ID=your-firebase-project-id
