# HealthBook — Environment Variables
# Copy this to .env and fill in real values

# Flask
SECRET_KEY=generate-a-random-64-char-string-here
FLASK_ENV=production
FLASK_DEBUG=false

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Firebase Phone Auth (https://console.firebase.google.com)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_PROJECT_ID=your-firebase-project-id

# Admin setup — set this to your Google email on first run to get admin role
